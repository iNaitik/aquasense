DATABASE_URL=postgresql://postgres:password@localhost:5432/aquasense
FRONTEND_ORIGIN=http://localhost:5173
PIPELINE_MATCH_MAX_DISTANCE_M=500
SECRET_KEY=replace_with_your_secure_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Notifications ----
NOTIFICATIONS_ENABLED=true
NOTIFICATION_PROVIDER=console

# MSG91 Configuration (required if NOTIFICATION_PROVIDER=msg91)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_TEMPLATE_ID_SUBMITTED=
MSG91_TEMPLATE_ID_REVIEWED=
MSG91_TEMPLATE_ID_ASSIGNED=
MSG91_TEMPLATE_ID_RESOLVED=
MSG91_SENDER_ID=

# Twilio Configuration (required if NOTIFICATION_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
